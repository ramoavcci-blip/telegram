# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3001
NODE_ENV=development

# Telegram Bot
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_FROM_BOTFATHER"

# API Configuration
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# JWT Secret (Production: use a strong random string with 32+ characters)
JWT_SECRET="your_super_secret_jwt_key_min_32_chars_for_production"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Database (Prisma)
# For SQLite (default):
# DATABASE_URL="file:./dev.db"
# For PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/telegramadmin"
# For MySQL:
# DATABASE_URL="mysql://user:password@localhost:3306/telegramadmin"
